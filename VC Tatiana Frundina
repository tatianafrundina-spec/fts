<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Татьяна Фрундина — визитная карточка</title>
  <style>
    :root {
      --bg: #eef2ef;
      --card: #ffffff;
      --text: #1f2a26;
      --muted: #65736d;
      --green: #60776b;
      --green-dark: #35483f;
      --green-light: #dbe5df;
      --line: #c8d3cd;
      --shadow: 0 20px 50px rgba(36, 54, 47, 0.14);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background: linear-gradient(135deg, #f5f7f5 0%, var(--bg) 48%, #dfe8e2 100%);
      padding: 36px 18px;
    }

    .card {
      max-width: 1080px;
      margin: 0 auto;
      background: var(--card);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      display: grid;
      grid-template-columns: 330px 1fr;
      overflow: hidden;
    }

    .sidebar {
      background: linear-gradient(180deg, var(--green-dark) 0%, #51695d 100%);
      color: #fff;
      padding: 34px 28px;
    }

    .photo-wrap {
      width: 190px;
      height: 190px;
      margin: 0 auto 28px;
      border-radius: 50%;
      border: 5px solid rgba(255,255,255,0.35);
      overflow: hidden;
      background: var(--green-light);
    }

    .photo-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain; object-position: center top; background:#dfe5df;
      display: block;
    }

    h1 {
      margin: 0 0 12px;
      font-size: 32px;
      line-height: 1.08;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .position {
      margin: 0 0 24px;
      color: #dce7e1;
      font-size: 15px;
      line-height: 1.5;
      font-weight: 600;
    }

    .contacts {
      padding-top: 22px;
      border-top: 1px solid rgba(255,255,255,0.25);
      display: grid;
      gap: 12px;
      font-size: 15px;
      line-height: 1.45;
    }

    .contacts a { color: #fff; text-decoration: none; }
    .contacts a:hover { text-decoration: underline; }

    .side-block {
      margin-top: 30px;
      padding-top: 22px;
      border-top: 1px solid rgba(255,255,255,0.25);
    }

    .side-title {
      margin: 0 0 14px;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #dce7e1;
      font-weight: 700;
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag {
      border: 1px solid rgba(255,255,255,0.28);
      padding: 7px 10px;
      font-size: 12px;
      color: #fff;
      background: rgba(255,255,255,0.08);
    }

    .content {
      padding: 38px 42px 42px;
    }

    .summary {
      margin: 0 0 28px;
      padding: 18px 20px;
      background: var(--green-light);
      border-left: 5px solid var(--green);
      font-size: 16px;
      line-height: 1.55;
      color: var(--green-dark);
      font-weight: 600;
    }

    section {
      margin-bottom: 28px;
      break-inside: avoid;
    }

    h2 {
      margin: 0 0 14px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
      font-size: 17px;
      line-height: 1.2;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--green-dark);
    }

    ul {
      margin: 0;
      padding-left: 18px;
      display: grid;
      gap: 8px;
    }

    li {
      font-size: 15px;
      line-height: 1.45;
    }

    .strengths {
      list-style: none;
      padding-left: 0;
    }

    .strengths li {
      position: relative;
      padding-left: 24px;
    }

    .strengths li::before {
      content: "✔";
      position: absolute;
      left: 0;
      top: 0;
      color: var(--green);
      font-weight: 700;
    }

    .columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }

    .footer-note {
      margin-top: 10px;
      color: var(--muted);
      font-size: 13px;
      border-top: 1px solid var(--line);
      padding-top: 16px;
    }

    @media (max-width: 860px) {
      .card { grid-template-columns: 1fr; }
      .sidebar { text-align: center; }
      .contacts { text-align: left; max-width: 320px; margin: 0 auto; }
      .columns { grid-template-columns: 1fr; gap: 0; }
      .content { padding: 30px 24px 34px; }
      h1 { font-size: 28px; }
    }

    @media print {
      body { padding: 0; background: #fff; }
      .card { box-shadow: none; border: none; max-width: none; }
      .sidebar { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
  </style>
</head>
<body>
